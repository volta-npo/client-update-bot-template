{
  "name": "@volta-oss/client-update-bot-template",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "A structured status-update assistant for keeping clients informed during 4-8 week student projects.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "npm run build && node --check src/*.js && node --check test/*.js",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm run lint && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/client-update-bot-template:local .",
    "docker:run": "docker compose up --build"
  },
  "keywords": [
    "ai-automation",
    "digital-equity",
    "local-first",
    "oss",
    "release",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/client-update-bot-template.git"
  },
  "homepage": "https://volta-npo.github.io/client-update-bot-template/",
  "bugs": {
    "url": "https://github.com/volta-npo/client-update-bot-template/issues"
  },
  "author": "Volta Open Source <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
